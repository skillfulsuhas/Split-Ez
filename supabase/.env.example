# --- Supabase (free tier) ---
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key (Settings -> API). SERVER-SIDE ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Google Gemini (free tier) ---
# From https://aistudio.google.com/app/apikey  (server-side only, do NOT prefix with NEXT_PUBLIC)
GEMINI_API_KEY=your_gemini_api_key

# --- Admin control room (/admin) ---
# A single shared password that unlocks the admin page where you manage the
# address book, browse/delete past splits, and view spending stats.
# Leave blank to disable the admin area entirely. Server-side only.
ADMIN_PASSWORD=your_admin_password
